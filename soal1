def is_prima(x):
    if x < 2:
        return False
    for i in range(2, int(x**0.5) + 1):
        if x % i == 0:
            return False
    return True

n = int(input("Masukkan nilai n: "))

for i in range(n - 1, 1, -1):
    if is_prima(i):
        print("Bilangan prima terdekat <", n, "adalah", i)
        break
else:
    print("Tidak ada bilangan prima <", n)
